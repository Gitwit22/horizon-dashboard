# Horizon Console Configuration

# Gateway/Agent API URL
# Computer A (Your System): 10.0.0.27
# Computer B (My System/Agent): 10.0.0.194
VITE_GATEWAY_URL=http://10.0.0.194:3001

# Auth (preferred)
# If your gateway supports JWT auth, set a bearer token here.
VITE_AUTH_TOKEN=

# Auth (fallback)
# If JWT isn't available, the console falls back to x-user-id.
VITE_USER_ID=console-user

# Optional multi-tenant/workspace header
VITE_WORKSPACE_ID=

# Optional client-side upload size guard (MB)
# Defaults to 25
VITE_MAX_UPLOAD_MB=25

# Console Port (when running locally)
VITE_PORT=5173
